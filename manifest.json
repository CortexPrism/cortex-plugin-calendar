{
  "name": "cortex-plugin-calendar",
  "version": "1.0.3",
  "description": "Read/write Google Calendar, schedule meetings, find open slots",
  "kind": "esm",
  "entryPoint": "mod.ts",
  "runtime": "deno",
  "author": "CortexPrism",
  "license": "MIT",
  "repository": "https://github.com/CortexPrism/cortex-plugin-calendar",
  "homepage": "https://github.com/CortexPrism/cortex-plugin-calendar",
  "capabilities": [
    "tools",
    "network:fetch"
  ],
  "tools": [
    {
      "name": "calendar_list_events",
      "description": "List calendar events",
      "params": [
        {
          "name": "calendar_id",
          "type": "string",
          "description": "Calendar ID",
          "required": false,
          "defaultValue": "primary"
        },
        {
          "name": "time_min",
          "type": "string",
          "description": "Start time in ISO 8601 format",
          "required": false
        },
        {
          "name": "time_max",
          "type": "string",
          "description": "End time in ISO 8601 format",
          "required": false
        },
        {
          "name": "max_results",
          "type": "number",
          "description": "Maximum number of events to return",
          "required": false,
          "defaultValue": 20
        },
        {
          "name": "query",
          "type": "string",
          "description": "Free text search query",
          "required": false
        }
      ]
    },
    {
      "name": "calendar_create_event",
      "description": "Create a calendar event",
      "params": [
        {
          "name": "summary",
          "type": "string",
          "description": "Event title",
          "required": true
        },
        {
          "name": "start_time",
          "type": "string",
          "description": "Start time in ISO 8601 format",
          "required": true
        },
        {
          "name": "end_time",
          "type": "string",
          "description": "End time in ISO 8601 format",
          "required": true
        },
        {
          "name": "description",
          "type": "string",
          "description": "Event description",
          "required": false
        },
        {
          "name": "attendees",
          "type": "string",
          "description": "Comma-separated email addresses of attendees",
          "required": false
        },
        {
          "name": "location",
          "type": "string",
          "description": "Event location",
          "required": false
        }
      ]
    },
    {
      "name": "calendar_find_slots",
      "description": "Find open slots across attendees",
      "params": [
        {
          "name": "attendees",
          "type": "string",
          "description": "Comma-separated email addresses of attendees",
          "required": true
        },
        {
          "name": "date",
          "type": "string",
          "description": "Date in YYYY-MM-DD format",
          "required": true
        },
        {
          "name": "duration_minutes",
          "type": "number",
          "description": "Meeting duration in minutes",
          "required": false,
          "defaultValue": 30
        },
        {
          "name": "start_hour",
          "type": "number",
          "description": "Start of working hours",
          "required": false,
          "defaultValue": 9
        },
        {
          "name": "end_hour",
          "type": "number",
          "description": "End of working hours",
          "required": false,
          "defaultValue": 17
        }
      ]
    },
    {
      "name": "calendar_update_event",
      "description": "Update an existing calendar event",
      "params": [
        {
          "name": "event_id",
          "type": "string",
          "description": "Event ID to update",
          "required": true
        },
        {
          "name": "updates",
          "type": "string",
          "description": "JSON string of fields to update",
          "required": true
        }
      ]
    },
    {
      "name": "calendar_delete_event",
      "description": "Delete a calendar event",
      "params": [
        {
          "name": "event_id",
          "type": "string",
          "description": "Event ID to delete",
          "required": true
        },
        {
          "name": "notify_attendees",
          "type": "boolean",
          "description": "Whether to notify attendees",
          "required": false,
          "defaultValue": true
        }
      ]
    },
    {
      "name": "calendar_prep_brief",
      "description": "Prep a meeting brief from memory",
      "params": [
        {
          "name": "event_id",
          "type": "string",
          "description": "Event ID to prepare brief for",
          "required": true
        }
      ]
    }
  ],
  "ui": {
    "settings": [
      {
        "section": "Google Calendar",
        "fields": [
          {
            "key": "calendarClientId",
            "label": "Calendar Client ID",
            "type": "text",
            "description": "Google Cloud OAuth 2.0 client ID",
            "required": true
          },
          {
            "key": "calendarClientSecret",
            "label": "Calendar Client Secret",
            "type": "secret",
            "description": "Google Cloud OAuth 2.0 client secret",
            "required": true
          },
          {
            "key": "calendarRefreshToken",
            "label": "Calendar Refresh Token",
            "type": "secret",
            "description": "Google Calendar API refresh token",
            "required": true
          },
          {
            "key": "defaultDuration",
            "label": "Default Event Duration",
            "type": "number",
            "description": "Default event duration in minutes",
            "required": false,
            "defaultValue": 30
          }
        ]
      }
    ]
  },
  "dependencies": {},
  "peerDependencies": {
    "cortex": ">=0.51.0"
  },
  "aiDisclosure": {
    "tools": [
      "Claude Code (Anthropic)"
    ],
    "humanReview": true
  }
}
